{
  "mcpServers": {
    "twin-mcp": {
      "command": "python",
      "args": [
        "-m",
        "twin_mcp.server"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "TWIN_AUDIT_DIR": "${workspaceFolder}/audit_trail",
        "TWIN_CASSETTE_DIR": "${workspaceFolder}/golden_cassettes",
        "PYTHONUNBUFFERED": "1"
      },
      "alwaysAllow": [
        "capture_baseline",
        "replay_and_diff",
        "compute_drift_metrics",
        "generate_audit_report"
      ],
      "disabled": false
    }
  }
}
